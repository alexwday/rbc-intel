# Database connection
DB_HOST=localhost
DB_PORT=34532
DB_NAME=rbc_intel
DB_USER=alexwday
DB_PASSWORD=
DB_SCHEMA=public

# LLM — set OPENAI_API_KEY for local dev; OAuth settings for production
OPENAI_API_KEY=
AZURE_BASE_URL=https://api.openai.com/v1

# OAuth (production only — not needed if OPENAI_API_KEY is set)
OAUTH_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Model tiers
RESEARCH_MODEL_SMALL=gpt-4o-mini
RESEARCH_MODEL_LARGE=gpt-4o
RESEARCH_MODEL_EMBEDDING=text-embedding-3-large

# Model costs (per 1K tokens, USD)
RESEARCH_MODEL_SMALL_PROMPT_COST=0.00015
RESEARCH_MODEL_SMALL_COMPLETION_COST=0.0006
RESEARCH_MODEL_LARGE_PROMPT_COST=0.0025
RESEARCH_MODEL_LARGE_COMPLETION_COST=0.01
RESEARCH_MODEL_EMBEDDING_PROMPT_COST=0.00013
RESEARCH_MODEL_EMBEDDING_COMPLETION_COST=0

# Pipeline settings
RESEARCH_MAX_HISTORY_LENGTH=10
RESEARCH_MAX_DATA_SOURCES_PER_QUERY=5
RESEARCH_LOG_LEVEL=INFO
RESEARCH_PROCESS_MONITOR_MODEL_NAME=research_pipeline
