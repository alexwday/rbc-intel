# =============================================================================
# AUTHENTICATION
# =============================================================================

# Mode: "oauth" or "api_key"
AUTH_MODE=api_key

# API key auth (when AUTH_MODE=api_key)
OPENAI_API_KEY=sk-...

# OAuth auth (when AUTH_MODE=oauth)
OAUTH_TOKEN_ENDPOINT=https://auth.example.com/oauth2/token
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_SCOPE=

# =============================================================================
# LLM ENDPOINT
# =============================================================================

LLM_ENDPOINT=https://api.openai.com/v1

# =============================================================================
# LLM MODELS — per stage
# Each stage uses {STAGE}_MODEL, {STAGE}_MAX_TOKENS, {STAGE}_TEMPERATURE,
# and optionally {STAGE}_REASONING_EFFORT.
#
# TEMPERATURE: Leave blank for models that don't support it (gpt-5-*, o-series)
# REASONING_EFFORT: Controls thinking depth. Values depend on your deployment:
#   - OpenAI public API: minimal, medium, high
#   - Azure deployments: may use low, medium, high instead
#   - Leave blank for default model behavior
# =============================================================================

# Startup — connection validation only
STARTUP_MODEL=gpt-5-mini
STARTUP_MAX_TOKENS=1000
STARTUP_TEMPERATURE=
STARTUP_REASONING_EFFORT=low

# Extraction — vision-based page processing
EXTRACTION_MODEL=gpt-5-mini
EXTRACTION_MAX_TOKENS=16000
EXTRACTION_TEMPERATURE=
EXTRACTION_REASONING_EFFORT=low
VISION_DPI_SCALE=2.0

# XLSX sheet classification
XLSX_CLASSIFICATION_MODEL=gpt-5-mini
XLSX_CLASSIFICATION_MAX_TOKENS=800
XLSX_CLASSIFICATION_TEMPERATURE=
XLSX_CLASSIFICATION_REASONING_EFFORT=low
XLSX_SHEET_TOKEN_LIMIT=80000
XLSX_CLASSIFICATION_MAX_RETRIES=3
XLSX_CLASSIFICATION_RETRY_DELAY_SECONDS=2.0

# Page continuation classification — PDF/DOCX page metadata
PAGE_CLASSIFICATION_MODEL=gpt-5-mini
PAGE_CLASSIFICATION_MAX_TOKENS=2000
PAGE_CLASSIFICATION_TEMPERATURE=
PAGE_CLASSIFICATION_REASONING_EFFORT=low

# PPTX slide classification — slide type and visual content
PPTX_CLASSIFICATION_MODEL=gpt-5-mini
PPTX_CLASSIFICATION_MAX_TOKENS=800
PPTX_CLASSIFICATION_TEMPERATURE=
PPTX_CLASSIFICATION_REASONING_EFFORT=low

# Dense table description — LLM-generated table summaries
DENSE_TABLE_DESCRIPTION_MODEL=gpt-5-mini
DENSE_TABLE_DESCRIPTION_MAX_TOKENS=4000
DENSE_TABLE_DESCRIPTION_TEMPERATURE=
DENSE_TABLE_DESCRIPTION_REASONING_EFFORT=low

# Content chunking — oversized page splitting
CONTENT_CHUNKING_MODEL=gpt-5-mini
CONTENT_CHUNKING_MAX_TOKENS=4000
CONTENT_CHUNKING_TEMPERATURE=
CONTENT_CHUNKING_REASONING_EFFORT=low

# Enrichment — page-level retrieval metadata
ENRICHMENT_MODEL=gpt-5-mini
ENRICHMENT_MAX_TOKENS=4000
ENRICHMENT_TEMPERATURE=
ENRICHMENT_REASONING_EFFORT=low

# Finalization — document-level metadata, sections, embeddings
FINALIZATION_MODEL=gpt-5-mini
FINALIZATION_MAX_TOKENS=16000
FINALIZATION_TEMPERATURE=
FINALIZATION_REASONING_EFFORT=low

# Content preparation — max tokens per chunk
CONTENT_PREP_MAX_CHUNK_TOKENS=8191

# Dense table description — max prompt tokens
DENSE_TABLE_DESCRIPTION_MAX_PROMPT_TOKENS=12000

# Enrichment retries
ENRICHMENT_MAX_RETRIES=3
ENRICHMENT_RETRY_DELAY_SECONDS=2.0

# Finalization settings
FINALIZATION_MAX_RETRIES=3
FINALIZATION_RETRY_DELAY_SECONDS=2.0
FINALIZATION_EMBEDDING_BATCH_SIZE=100
FINALIZATION_EMBEDDING_MODEL=text-embedding-3-large
FINALIZATION_CHUNK_SUMMARY_BATCH_SIZE=10
FINALIZATION_METADATA_PAGE_COUNT=5
FINALIZATION_MAX_CLASSIFICATION_PAGES=100
FINALIZATION_CONTEXT_CHAIN_DEPTH=3
FINALIZATION_DEGRADATION_SIGNAL_THRESHOLD=3

# =============================================================================
# DATA SOURCES
# =============================================================================

DATA_SOURCE_PATH=/path/to/rbc-intel/document_pipeline/test_data/runtime_sources
ACCEPTED_FILETYPES=pdf,docx,pptx,xlsx

# =============================================================================
# PIPELINE
# =============================================================================

MAX_WORKERS=4
RETENTION_COUNT=31

# =============================================================================
# DATABASE
# =============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbc_intel
DB_USER=your_username
DB_PASSWORD=

# Optional: push to Postgres during storage stage
# STORAGE_PUSH_TO_POSTGRES=true
